# sentinex Service Configuration
PORT=3001

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# News API (https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=your-cryptopanic-key-here

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract (from Phase 1 deployment)
SOROBAN_CONTRACT_ID=your-contract-id-here

# AI Agent Keypair (the operational key that signs trades)
STELLAR_AGENT_SECRET=your-agent-secret-key-here
STELLAR_AGENT_ADDRESS=your-agent-public-address-here

# Owner address (for reference/validation)
STELLAR_OWNER_ADDRESS=your-owner-public-address-here

# Risk defaults
DEFAULT_CONFIDENCE_THRESHOLD=65
SCAN_INTERVAL_SECONDS=120
